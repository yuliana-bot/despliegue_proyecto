def _obtener_contexto_usuario(user):
    """
    Trae datos contextuales de ACERAUTOS según el usuario logueado.
    Si es ADMIN ve todo, si no ve solo sus datos.
    """
    contexto = []
    
    # ── Información de la empresa ──
    contexto.append("=== INFORMACIÓN DE ACERAUTOS ===")
    contexto.append("ACERAUTOS es un taller especializado integral automotriz ubicado en Yopal, Casanare, Colombia.")
    contexto.append("Teléfono: +57 (8) 632-5678 | WhatsApp: +57 320 123 4567")
    contexto.append("Especialidades: Cambio de aceite, suspensión, frenos, transmisión, alineación, aire acondicionado, diagnóstico computarizado.")
    contexto.append("")
    
    # ── Órdenes recientes ──
    contexto.append("=== ÓRDENES DE SERVICIO RECIENTES ===")
    if user.cargo == 'ADMIN' or user.is_superuser:
        ordenes = OrdenServicio.objects.select_related(
            'vehiculo', 'vehiculo__cliente', 'vehiculo__marca'
        ).order_by('-fecha')[:10]
    else:
        ordenes = OrdenServicio.objects.filter(
            vehiculo__cliente__user=user
        ).select_related(
            'vehiculo', 'vehiculo__cliente', 'vehiculo__marca'
        ).order_by('-fecha')[:5]
    
    for orden in ordenes:
        estado_texto = f"[{orden.estado}]"
        placa = orden.vehiculo.placa if orden.vehiculo else "Sin vehículo"
        monto = f"${orden.valor_total:,.0f}" if hasattr(orden, 'valor_total') and orden.valor_total else "Por definir"
        fecha_str = orden.fecha.strftime('%d/%m/%Y') if orden.fecha else "N/A"
        contexto.append(
            f"- Orden #{orden.id}: {placa} - {estado_texto} - {monto} - Fecha: {fecha_str}"
        )
    contexto.append("")
    
    # ── Vehículos ──
    contexto.append("=== VEHÍCULOS REGISTRADOS ===")
    if user.cargo == 'ADMIN' or user.is_superuser:
        vehiculos = Vehiculo.objects.select_related('marca', 'cliente')[:10]
    else:
        vehiculos = Vehiculo.objects.filter(
            cliente__user=user
        ).select_related('marca', 'cliente')
    
    if vehiculos.exists():
        for v in vehiculos:
            contexto.append(f"- {v.placa}: {v.marca.nombre} {v.modelo} ({v.anio}) - Cliente: {v.cliente.nombre if v.cliente else 'N/A'}")
    else:
        contexto.append("- Sin vehículos registrados")
    contexto.append("")
    
    # ── Servicios disponibles ──
    contexto.append("=== SERVICIOS DISPONIBLES ===")
    servicios = TipoServicio.objects.filter(activo=True)[:15]
    if servicios.exists():
        for s in servicios:
            contexto.append(f"- {s.nombre}: ${s.valor_base:,.0f}" if s.valor_base else f"- {s.nombre}")
    else:
        contexto.append("- Consulta con nuestro equipo para servicios personalizados")
    contexto.append("")
    
    # ── Próximos mantenimientos ──
    contexto.append("=== PRÓXIMOS MANTENIMIENTOS ===")
    hoy = timezone.now().date()
    seguimientos = SeguimientoMantenimiento.objects.filter(
        activo=True,
        fecha_proximo_mantenimiento__isnull=False
    ).select_related('vehiculo', 'tipo_servicio').order_by('fecha_proximo_mantenimiento')[:5]
    
    if seguimientos.exists():
        for seg in seguimientos:
            dias = (seg.fecha_proximo_mantenimiento - hoy).days
            contexto.append(
                f"- {seg.vehiculo.placa}: {seg.tipo_servicio.nombre} - "
                f"{seg.fecha_proximo_mantenimiento.strftime('%d/%m/%Y')} "
                f"(en {dias} días)"
            )
    else:
        contexto.append("- Sin mantenimientos programados")
    contexto.append("")
    
    # ── Notificaciones pendientes ──
    contexto.append("=== ALERTAS ACTIVAS ===")
    notificaciones = Notificacion.objects.filter(leido=False).select_related('vehiculo')[:5]
    if notificaciones.exists():
        for n in notificaciones:
            contexto.append(f"- {n.tipo}: {n.titulo} - {n.vehiculo.placa if n.vehiculo else 'General'}")
    else:
        contexto.append("- Sin alertas pendientes")
    
    return "\n".join(contexto)


# ── SYSTEM PROMPT MEJORADO ────────────────────────────────────────
def _generar_system_prompt(user):
    """
    Genera un prompt del sistema dinámico con contexto de ACERAUTOS.
    """
    contexto = _obtener_contexto_usuario(user)
    
    prompt = f"""Eres un asistente de atención al cliente de ACERAUTOS, un taller especializado integral automotriz.

Tu rol:
- Responder preguntas sobre órdenes de servicio, vehículos y mantenimientos
- Proporcionar información sobre servicios, precios y disponibilidad
- Ayudar con consultas sobre citas y mantenimiento preventivo
- Ser amable, profesional y respetuoso
- Si algo no está en la información proporcionada, sugiere contactar directamente

CONTEXTO ACTUAL DE ACERAUTOS:

{contexto}

Instrucciones:
1. Responde en español
2. Sé específico si se pregunta sobre órdenes, vehículos o servicios (usa los datos anteriores)
3. Si alguien pregunta por un servicio que no está listado, ofrece consultarlo
4. Mantén un tono profesional pero amable
5. Para consultas urgentes, sugiere llamar: +57 (8) 632-5678
"""
    
    return prompt


@csrf_exempt
@login_required(login_url='login:login')
def chatbot_responder(request):
    """
    Endpoint para chatbot con Ollama integrado a BD de ACERAUTOS.
    """
    if request.method != 'POST':
        return JsonResponse({'error': 'Método no permitido'}, status=405)

    try:
        data    = json.loads(request.body)
        mensaje = data.get('mensaje', '').strip()

        if not mensaje:
            return JsonResponse({'error': 'Mensaje vacío'}, status=400)

        # ── Generar prompt dinámico con contexto ──
        system_prompt = _generar_system_prompt(request.user)

        # ── Llamar a Ollama con contexto ──
        respuesta = ollama.chat(
            model='mistral',
            messages=[
                {'role': 'system', 'content': system_prompt},
                {'role': 'user',   'content': mensaje}
            ],
            stream=False  # Sin streaming para respuesta completa
        )

        texto = respuesta['message']['content']
        return JsonResponse({'respuesta': texto})

    except Exception as e:
        print(f"[CHATBOT ERROR] {str(e)}")
        return JsonResponse({
            'error': 'Error al procesar tu pregunta',
            'detalle': str(e)
        }, status=500)


