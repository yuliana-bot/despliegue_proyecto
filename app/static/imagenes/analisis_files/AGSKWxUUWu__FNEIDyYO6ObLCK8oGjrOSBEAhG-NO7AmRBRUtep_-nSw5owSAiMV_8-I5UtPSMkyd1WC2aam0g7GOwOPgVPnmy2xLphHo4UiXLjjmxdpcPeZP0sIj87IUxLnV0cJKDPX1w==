def chatbot_responder_stream(request):
    """
    Versión con streaming (respuestas más rápidas, se ven en tiempo real).
    Usa Server-Sent Events (SSE) si lo necesitas más tarde.
    """
    if request.method != 'POST':
        return JsonResponse({'error': 'Método no permitido'}, status=405)

    try:
        data    = json.loads(request.body)
        mensaje = data.get('mensaje', '').strip()

        if not mensaje:
            return JsonResponse({'error': 'Mensaje vacío'}, status=400)

        system_prompt = _generar_system_prompt(request.user)

        # ── Con stream=True para ver respuesta parcial ──
        stream_respuesta = ollama.chat(
            model='mistral',
            messages=[
                {'role': 'system', 'content': system_prompt},
                {'role': 'user',   'content': mensaje}
            ],
            stream=True
        )

        # Acumular respuesta completa
        texto_completo = ""
        for chunk in stream_respuesta:
            texto_completo += chunk['message']['content']

        return JsonResponse({'respuesta': texto_completo})

    except Exception as e:
